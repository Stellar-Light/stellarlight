{
	"name": "stellarlight",
	"version": "1.0.0",
	"description": "A comprehensive directory and discovery platform for the Stellar ecosystem",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"typecheck": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && pnpm exec tsc --noEmit",
		"build": "pnpm typecheck && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build --webpack",
		"check": "biome check .",
		"dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
		"dev:fresh": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && cross-env NODE_OPTIONS=--no-deprecation next dev",
		"devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
		"format": "biome format --write .",
		"generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
		"generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
		"lint": "biome lint .",
		"payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
		"start": "cross-env NODE_OPTIONS=--no-deprecation next start",
		"seed:lumenloop": "curl -X POST \"$NEXT_PUBLIC_APP_URL/api/sync/lumenloop\" -H \"Authorization: Bearer <ADMIN_TOKEN>\"",
		"test": "vitest run",
		"test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
		"test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
		"test:watch": "vitest",
		"cron:github": "cross-env NODE_OPTIONS=--no-deprecation pnpm exec tsx jobs/refresh-github.ts",
		"openapi:lint": "spectral lint https://stellarlight.xyz/api/openapi.json --ruleset .spectral.yaml --fail-severity=error"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.109.1",
		"@aws-sdk/client-s3": "^3.926.0",
		"@aws-sdk/lib-storage": "^3.926.0",
		"@aws-sdk/s3-request-presigner": "^3.926.0",
		"@next/font": "^14.2.15",
		"@number-flow/react": "^0.6.0",
		"@payloadcms/db-mongodb": "3.63.0",
		"@payloadcms/email-resend": "3.63.0",
		"@payloadcms/next": "3.63.0",
		"@payloadcms/payload-cloud": "3.63.0",
		"@payloadcms/plugin-cloud-storage": "^3.63.0",
		"@payloadcms/richtext-lexical": "3.63.0",
		"@payloadcms/storage-r2": "^3.63.0",
		"@payloadcms/storage-s3": "^3.63.0",
		"@payloadcms/storage-vercel-blob": "^3.63.0",
		"@payloadcms/ui": "3.63.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-slot": "^1.2.3",
		"@tanstack/react-query": "^5.90.10",
		"@vercel/analytics": "^2.0.1",
		"@vercel/blob": "^2.0.0",
		"@visx/curve": "4.0.1-alpha.0",
		"@visx/event": "4.0.1-alpha.0",
		"@visx/gradient": "4.0.1-alpha.0",
		"@visx/grid": "4.0.1-alpha.0",
		"@visx/responsive": "4.0.1-alpha.0",
		"@visx/scale": "4.0.1-alpha.0",
		"@visx/shape": "4.0.1-alpha.0",
		"airtable": "^0.12.2",
		"cross-env": "^7.0.3",
		"d3-array": "^3.2.4",
		"date-fns": "^4.1.0",
		"dotenv": "16.4.7",
		"embla-carousel-react": "^8.6.0",
		"graphql": "^16.8.1",
		"js-yaml": "^4.1.1",
		"motion": "^12.38.0",
		"next": "16.0.10",
		"payload": "3.63.0",
		"pdf-parse": "^2.4.5",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-icons": "^5.4.0",
		"react-markdown": "^10.1.0",
		"react-use-measure": "^2.1.7",
		"remark-gfm": "^4.0.1",
		"rss-parser": "^3.13.0",
		"sharp": "0.34.2",
		"simple-git": "^3.29.0",
		"vaul": "^1.1.2",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.2",
		"@playwright/test": "1.54.1",
		"@stoplight/spectral-cli": "^6.16.1",
		"@testing-library/react": "16.3.0",
		"@types/d3-array": "^3.2.2",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.5.4",
		"@types/react": "19.1.8",
		"@types/react-dom": "19.1.6",
		"@vitejs/plugin-react": "4.5.2",
		"autoprefixer": "^10.4.21",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"eslint": "^9.16.0",
		"eslint-config-next": "16.0.10",
		"happy-dom": "^20.0.10",
		"jsdom": "26.1.0",
		"lucide-react": "^0.552.0",
		"playwright": "1.54.1",
		"playwright-core": "1.54.1",
		"postcss": "^8.5.6",
		"prettier": "^3.4.2",
		"tailwind-merge": "^3.3.1",
		"tailwindcss": "^3.4.1",
		"tailwindcss-animate": "^1.0.7",
		"tsx": "^4.20.6",
		"typescript": "5.7.3",
		"vite-tsconfig-paths": "5.1.4",
		"vitest": "3.2.3"
	},
	"engines": {
		"node": "24.12.0",
		"pnpm": "^9 || ^10"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp",
			"esbuild",
			"unrs-resolver"
		]
	}
}
