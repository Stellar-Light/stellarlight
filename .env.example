# ============================================
# StellarLight Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# ============================================
# Database Configuration
# ============================================
# MongoDB connection string (required)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name?retryWrites=true&w=majority
MONGODB_URI=
# Alternative to MONGODB_URI (either MONGODB_URI or DATABASE_URI is required)
DATABASE_URI=

# ============================================
# Payload CMS Configuration
# ============================================
# Secret key for Payload CMS (required, minimum 32 characters)
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=

# ============================================
# Application URL
# ============================================
# Your deployed site URL (required)
# For local development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# Cloudflare R2 Storage (for media uploads)
# ============================================
# Required for media uploads. Admin panel works without them, but uploads won't persist.
# See DEPLOYMENT.md for setup instructions: https://dash.cloudflare.com/r2

# Cloudflare R2 Access Key ID
R2_ACCESS_KEY_ID=

# Cloudflare R2 Secret Access Key
R2_SECRET_ACCESS_KEY=

# Cloudflare R2 Endpoint URL
# Format: https://abc123.r2.cloudflarestorage.com
R2_ENDPOINT=

# Cloudflare R2 Bucket Name
# Example: stellarlight-media
R2_BUCKET=

# Cloudflare R2 Region
# Use "auto" for automatic region selection
R2_REGION=auto

# ============================================
# Cron Job Security
# ============================================
# Secret for securing cron endpoints (required)
# Generate with: openssl rand -base64 32
# Vercel automatically sets VERCEL_CRON_SECRET, but you can also use CRON_SECRET
CRON_SECRET=

# ============================================
# GitHub API (Optional)
# ============================================
# GitHub personal access token for enhanced API rate limits
# Create at: https://github.com/settings/tokens
# Permissions needed: public_repo (read-only)
GITHUB_TOKEN=

# ============================================
# Airtable Integration (Optional)
# ============================================
# Airtable API key for syncing projects from Airtable
# Get from: https://airtable.com/account
AIRTABLE_API_KEY=

# Airtable Base ID (optional, has defaults)
AIRTABLE_BASE_ID=appnaTSKcxJfsgTQy

# Airtable Table ID (optional, has defaults)
AIRTABLE_TABLE_ID=tblWf69pEPyhW8ntO

# Airtable View ID (optional, has defaults)
AIRTABLE_VIEW_ID=viwVVnH1gnbI9Fa7t

# ============================================
# Lumenloop Sync (Optional)
# ============================================
# Path to local Lumenloop repository for syncing projects
# Only needed if using the Lumenloop sync feature
LUMENLOOP_PATH=

# ============================================
# Notes
# ============================================
# - For local development, copy this file to .env.local
# - For Vercel deployment, add these variables in Vercel Dashboard → Settings → Environment Variables
# - R2 variables are required for media uploads to work in production
# - See DEPLOYMENT.md for detailed setup instructions
# Voyage AI key for Scout research-corpus embeddings (voyage-3, Anthropic-recommended)
# Used by /scripts/ingest-*.py at ingestion time and by /api/research
# at query-embed time. Get one at https://dash.voyageai.com/api-keys
VOYAGE_API_KEY=

# Outbound email (partner digest, invites, password resets). Without a key,
# emails are logged to console instead of sent (dev-safe).
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=hello@stellarlight.xyz
EMAIL_FROM_NAME=Stellar Light
# Where new-listing / claim-request notifications go
ADMIN_NOTIFY_EMAIL=
# Absolute origin used in emailed links (password reset, invites)
NEXT_PUBLIC_APP_URL=https://stellarlight.xyz
